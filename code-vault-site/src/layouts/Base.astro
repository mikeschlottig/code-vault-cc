---
/**
 * src/layouts/Base.astro
 * Root layout — dark industrial aesthetic, monospace accents, Cloudflare-fast.
 */
import type { ArtifactData } from '@lib/types';

interface Props {
  title?:       string;
  description?: string;
  og?:          Partial<ArtifactData>;
}

const {
  title = 'Code Vault',
  description = 'Every artifact from every conversation — browsable, searchable, queryable.',
} = Astro.props;

const fullTitle = title === 'Code Vault' ? title : `${title} — Code Vault`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=Instrument+Serif:ital@0;1&display=swap"
    rel="stylesheet"
  />

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* Palette */
      --void:      #0a0b0c;
      --pit:       #111315;
      --well:      #181b1e;
      --surface:   #1f2226;
      --panel:     #252a2f;
      --rim:       #2e3338;
      --ghost:     #3d444c;
      --mist:      #5c6570;
      --ash:       #8a9099;
      --fog:       #b8bfc8;
      --chalk:     #dde3ea;
      --snow:      #f0f4f8;

      /* Accent ramp */
      --amber:     #e8960a;
      --amber-dim: #2a1c04;
      --amber-mid: #6b420a;
      --teal:      #12a086;
      --teal-dim:  #041f1b;
      --coral:     #d9503a;
      --coral-dim: #2a0e09;
      --purple:    #7c5ce8;
      --purple-dim:#160e32;

      /* Semantic */
      --bg:        var(--void);
      --bg2:       var(--pit);
      --bg3:       var(--well);
      --border:    var(--rim);
      --border-dim:var(--ghost);
      --text:      var(--chalk);
      --text-dim:  var(--ash);
      --text-muted:var(--mist);

      /* Typography */
      --mono: 'IBM Plex Mono', 'Courier New', monospace;
      --serif:'Instrument Serif', Georgia, serif;
    }

    html { background: var(--bg); color: var(--text); scroll-behavior: smooth; }

    body {
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    a { color: var(--amber); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: var(--pit); }
    ::-webkit-scrollbar-thumb { background: var(--ghost); border-radius: 2px; }

    /* ── Focus ── */
    :focus-visible {
      outline: 1px solid var(--amber);
      outline-offset: 2px;
    }

    /* ── Utility ── */
    .sr-only {
      position: absolute; width: 1px; height: 1px;
      padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }

    .tag-pill {
      display: inline-block;
      font-size: 10px; font-weight: 500;
      padding: 2px 7px; border-radius: 2px;
      background: var(--well); color: var(--ash);
      border: 1px solid var(--rim);
      letter-spacing: 0.04em;
    }

    .lang-badge {
      display: inline-block;
      font-size: 10px; font-weight: 700;
      padding: 2px 8px; border-radius: 2px;
      letter-spacing: 0.08em;
    }
  </style>
</head>
<body>
  <!-- ── NAV ── -->
  <nav style="
    display:flex; align-items:center; gap:0;
    border-bottom: 1px solid var(--rim);
    background: var(--pit);
    position: sticky; top: 0; z-index: 50;
  ">
    <a href="/" style="
      padding: 10px 20px;
      font-size: 12px; font-weight: 700;
      letter-spacing: 0.12em; color: var(--amber);
      border-right: 1px solid var(--rim);
      text-decoration: none;
      white-space: nowrap;
    ">⬛ CODE VAULT</a>

    <div style="display:flex; flex:1; overflow-x:auto;">
      {[
        ['/vault/page/1/',        'gallery'],
        ['/vault/renderable/',    'renderable'],
        ['/vault/by-lang/',       'by lang'],
        ['/vault/by-tag/',        'by tag'],
        ['/vault/conversations/', 'conversations'],
        ['/graph/',               'graph'],
        ['/query/',               'duckdb'],
      ].map(([href, label]) => (
        <a
          href={href}
          style="
            padding: 10px 16px;
            font-size: 11px; font-weight: 500;
            letter-spacing: 0.08em;
            color: var(--ash);
            border-right: 1px solid var(--rim);
            white-space: nowrap;
            text-decoration: none;
            transition: color 0.1s;
          "
          data-nav-link
        >{label}</a>
      ))}
    </div>

    <a
      href="/api/manifest.json"
      style="
        padding: 10px 16px;
        font-size: 10px; letter-spacing: 0.1em;
        color: var(--mist); border-left: 1px solid var(--rim);
        white-space: nowrap; text-decoration: none;
      "
    >JSON ↗</a>
  </nav>

  <!-- ── CONTENT ── -->
  <main style="flex:1">
    <slot />
  </main>

  <!-- ── FOOTER ── -->
  <footer style="
    border-top: 1px solid var(--rim);
    padding: 12px 20px;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 10px; color: var(--mist);
    letter-spacing: 0.06em;
  ">
    <span>⬛ LEVERAGEAI CODE VAULT</span>
    <span>GRANTS PASS, OR · CLOUDFLARE WORKERS</span>
    <a href="/api/manifest.json" style="color:var(--mist)">manifest.json</a>
  </footer>

  <!-- Active nav link highlight -->
  <script>
    const path = window.location.pathname;
    document.querySelectorAll('[data-nav-link]').forEach(link => {
      if (path.startsWith(link.getAttribute('href') ?? '')) {
        (link as HTMLElement).style.color = 'var(--amber)';
      }
    });
  </script>
</body>
</html>
