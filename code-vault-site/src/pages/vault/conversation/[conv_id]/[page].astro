---
/**
 * src/pages/vault/conversation/[conv_id]/[page].astro
 * All artifacts from a single source conversation.
 * Routes: /vault/conversation/abc123/1/, …
 */
import Base               from '@layouts/Base.astro';
import ArtifactCard       from '@components/ArtifactCard.astro';
import Pagination         from '@components/Pagination.astro';
import { conversationStaticPaths, paginate } from '@lib/artifacts';
import type { ArtifactEntry }                from '@lib/types';

export const getStaticPaths = conversationStaticPaths;

interface Props {
  conv_id:    string;
  conv_title: string;
  page:       number;
  entries:    ArtifactEntry[];
  totalPages: number;
}

const { conv_id, conv_title, page, entries, totalPages } = Astro.props;
const paged = paginate(entries, page);
---
<Base title={`${conv_title} — Page ${page}`}>
  <div style="
    padding:1rem 2rem; border-bottom:1px solid var(--rim);
    display:flex; align-items:flex-start; justify-content:space-between;
    flex-wrap:wrap; gap:8px;
  ">
    <div>
      <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px">
        <a href="/vault/conversations/" style="font-size:10px; color:var(--mist); text-decoration:none; letter-spacing:0.06em">CONVERSATIONS</a>
        <span style="color:var(--ghost)">/</span>
        <span style="font-size:10px; color:var(--mist); font-family:var(--mono)">{conv_id.slice(0,12)}…</span>
      </div>
      <h1 style="font-size:14px; font-weight:600; color:var(--chalk)">{conv_title}</h1>
      <p style="font-size:10px; color:var(--mist); margin-top:3px">{paged.totalItems} artifacts extracted</p>
    </div>
  </div>

  <div style="
    display:grid; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr));
    gap:12px; padding:1.25rem 2rem;
  ">
    {paged.items.map(entry => (
      <ArtifactCard entry={entry} />
    ))}
  </div>

  <Pagination
    currentPage={paged.currentPage}
    totalPages={totalPages}
    baseHref={`/vault/conversation/${conv_id}/`}
  />
</Base>
