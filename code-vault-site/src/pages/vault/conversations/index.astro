---
/**
 * src/pages/vault/conversations/index.astro
 * Conversation index — all source conversations, sorted by artifact count.
 */
import Base                    from '@layouts/Base.astro';
import { getConversationIndex } from '@lib/artifacts';

const convs = await getConversationIndex();
---
<Base title="By Conversation">
  <div style="padding:1rem 2rem; border-bottom:1px solid var(--rim)">
    <h1 style="font-size:10px; letter-spacing:0.18em; color:var(--mist); font-weight:500; text-transform:uppercase">
      // BY CONVERSATION — {convs.length}
    </h1>
  </div>

  <div style="display:flex; flex-direction:column; gap:0">
    {convs.map(({ conv_id, conv_title, count }) => (
      <a
        href={`/vault/conversation/${conv_id}/1/`}
        style="
          display:flex; align-items:center; justify-content:space-between;
          padding:10px 2rem; border-bottom:1px solid var(--rim);
          text-decoration:none; transition: background 0.1s;
        "
      >
        <div style="display:flex; align-items:baseline; gap:12px; flex:1; min-width:0">
          <span style="font-size:10px; color:var(--mist); font-family:var(--mono); flex-shrink:0">
            {conv_id.slice(0, 8)}…
          </span>
          <span style="
            font-size:12px; color:var(--chalk); font-weight:500;
            white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
          ">
            {conv_title}
          </span>
        </div>
        <span style="
          font-size:11px; font-weight:600; color:var(--amber);
          flex-shrink:0; margin-left:1rem;
        ">
          {count} artifacts →
        </span>
      </a>
    ))}
  </div>
</Base>
